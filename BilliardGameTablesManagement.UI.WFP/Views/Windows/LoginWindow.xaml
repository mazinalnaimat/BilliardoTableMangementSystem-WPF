<Window x:Class="BilliardGameTablesManagement.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Width="420"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#D7DEE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#2D7FF9"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <DataTrigger Binding="{Binding HasUsernameError}" Value="True">
                    <Setter Property="BorderBrush" Value="#D93025"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#D7DEE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#2D7FF9"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <DataTrigger Binding="{Binding HasPasswordError}" Value="True">
                    <Setter Property="BorderBrush" Value="#D93025"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Width="330"
                Padding="25"
                Background="White"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>

                <TextBlock Text="Login"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Enter your account details"
                           Foreground="#6B7280"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,22"/>

                <TextBlock Text="Username"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource LoginTextBoxStyle}"
                         Margin="0,0,0,4"/>

                <TextBlock Text="{Binding UsernameError}"
                           Foreground="#D93025"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasUsernameError, Converter={StaticResource BooleanToVisibilityConverter}}"
                           Margin="2,0,0,10"/>

                <TextBlock Text="Password"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource LoginPasswordBoxStyle}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Margin="0,0,0,4"/>

                <TextBlock Text="{Binding PasswordError}"
                           Foreground="#D93025"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasPasswordError, Converter={StaticResource BooleanToVisibilityConverter}}"
                           Margin="2,0,0,14"/>

                <Button Content="Login"
                        Command="{Binding LoginCommand}"
                        IsDefault="True"
                        Height="38"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Background="#1F7A4D"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,12"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#D93025"
                           Background="#FDECEC"
                           Padding="10,7"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                           Margin="0,0,0,10"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
