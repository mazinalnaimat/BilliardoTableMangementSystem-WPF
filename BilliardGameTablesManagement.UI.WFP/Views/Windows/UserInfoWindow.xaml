<Window x:Class="BilliardGameTablesManagement.Views.Windows.UserInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Information"
        Width="440"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F6"
        Icon="/Resources/imgs/billiardo game table magement.png">

    <Window.Resources>
        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6E7B86"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D2C38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#176B4D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="19"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0F5C42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="White"
                CornerRadius="18"
                BorderBrush="#D8E0E7"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="150"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="74"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        CornerRadius="18,18,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#15352A" Offset="0"/>
                            <GradientStop Color="#1F7A4D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="64"
                                Height="64"
                                CornerRadius="32"
                                Background="#33FFFFFF"
                                BorderBrush="#66FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserInfo.Initials}"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <TextBlock Text="{Binding UserInfo.DisplayName}"
                                       Foreground="White"
                                       FontSize="23"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding UserInfo.Username, StringFormat='@{0}'}"
                                       Foreground="#DDEEE7"
                                       FontSize="13"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24,22,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Email" Style="{StaticResource CaptionTextStyle}"/>
                        <TextBlock Text="{Binding UserInfo.Email, FallbackValue='-'}" Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Phone" Style="{StaticResource CaptionTextStyle}"/>
                        <TextBlock Text="{Binding UserInfo.Phone, FallbackValue='-'}" Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Date of Birth" Style="{StaticResource CaptionTextStyle}"/>
                        <TextBlock Text="{Binding UserInfo.DateOfBirth, StringFormat='{}{0:yyyy-MM-dd}', TargetNullValue='-'}"
                                   Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Gender" Style="{StaticResource CaptionTextStyle}"/>
                        <TextBlock Text="{Binding UserInfo.Gender, FallbackValue='-'}" Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Text="Nationality No." Style="{StaticResource CaptionTextStyle}"/>
                        <TextBlock Text="{Binding UserInfo.NationalityNumber, TargetNullValue='-'}"
                                   Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock Text="User ID" Style="{StaticResource CaptionTextStyle}"/>
                        <TextBlock Text="{Binding UserInfo.UserId, TargetNullValue='-'}"
                                   Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="Address" Style="{StaticResource CaptionTextStyle}"/>
                        <TextBlock Text="{Binding UserInfo.Address, FallbackValue='-'}" Style="{StaticResource ValueTextStyle}"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        BorderBrush="#E4EAF0"
                        BorderThickness="0,1,0,0"
                        Padding="24,16">
                    <Button Content="Close"
                            HorizontalAlignment="Right"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource CloseButtonStyle}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
