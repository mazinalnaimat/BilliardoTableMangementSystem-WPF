<Window x:Class="BilliardGameTablesManagement.BilliardTablesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:BilliardGameTablesManagement.Views.Controls"
        Title="Billiardo Tables Mangement"
        Height="680"
        Width="800"
        ResizeMode="NoResize"
        Icon="/Resources/imgs/billiardo game table magement.png"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F6">

    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#176B4D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="17"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0F5C42"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A8B3BD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="94"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="18,14"
                BorderBrush="#D8E0E7"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Billiard Tables"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#18242F"/>
                    <TextBlock Text="{Binding CurrentTime, StringFormat='Time: {0}', FallbackValue='Time: 00:00:00'}"
                               FontSize="13"
                               Foreground="#6B7680"
                               Margin="1,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Background="#F3F7F5"
                            BorderBrush="#D5E4DC"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14,6"
                            Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Signed in as"
                                       FontSize="10"
                                       Foreground="#65726C"/>
                            <TextBlock Text="{Binding CurrentUsername, FallbackValue='Unknown'}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#163C2E"/>
                        </StackPanel>
                    </Border>

                    <Button Content="User Info"
                            Command="{Binding ShowUserInfoCommand}"
                            Style="{StaticResource HeaderButtonStyle}"/>

                    <Button Content="Log out"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource HeaderButtonStyle}"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding Tables}"
                      Margin="0,18,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="2" Columns="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Controls:BilliardTableCardView
                        Width="182"
                        Height="200"
                        Margin="10"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
