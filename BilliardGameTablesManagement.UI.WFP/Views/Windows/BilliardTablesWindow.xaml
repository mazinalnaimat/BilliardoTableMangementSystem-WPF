<Window x:Class="BilliardGameTablesManagement.BilliardTablesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:BilliardGameTablesManagement.Views.Controls"
        Title="Billiardo Tables Mangement"
        Height="680"
        Width="800"
        ResizeMode="NoResize"
        Icon="/Resources/imgs/billiardo game table magement.png"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <TextBlock Text="{Binding CurrentTime, StringFormat='Time: {0:hh\\:mm\\:ss}',FallbackValue='Time: 00:00:00'}"
               FontSize="16"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,10,10,0"/>
        </Grid>
            
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Tables}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="2" Columns="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Controls:BilliardTableCardView
                        Width="182"
                        Height="200"
                        Margin="10"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
