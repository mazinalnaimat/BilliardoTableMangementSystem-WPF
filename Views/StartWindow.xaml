<Window x:Class="BilliardGameTablesManagement.Views.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Billiard Tables Management" Height="300" Width="400"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Icon="/Resources/imgs/billiardo game table magement.png">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Welcome to Billiard Hall" 
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,30"/>
            <Button Content="Start Program" 
                    Command="{Binding StartProgramCommand}" 
                    Width="150" Height="40" Margin="0,10"/>
            <Button Content="Exit" 
                    Command="{Binding ExitCommand}" 
                    Width="150" Height="40" Margin="0,10"/>
        </StackPanel>
    </Grid>
</Window>