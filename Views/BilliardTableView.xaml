<UserControl x:Class="BilliardGameTablesManagement.Views.BilliardTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BilliardGameTablesManagement.Views"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="220"
             MinWidth="200" MinHeight="200">
	<!-- Simple billiard table design + time management -->
	<Border BorderBrush="Gray" BorderThickness="2" CornerRadius="8" Background="#FFF8F8F8"
            Padding="10">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<!-- Table number -->
				<RowDefinition Height="*"/>
				<!-- Table drawing -->
				<RowDefinition Height="Auto"/>
				<!-- Timer & cost -->
				<RowDefinition Height="Auto"/>
				<!-- Buttons -->
			</Grid.RowDefinitions>

			<!-- 1. Table number -->
			<TextBlock Grid.Row="0" Text="{Binding TableNumber, StringFormat='Table {0}'}"
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>

			<!-- 2. Billiard table visual -->
			<Viewbox Grid.Row="1" Stretch="Uniform">
				<Canvas Width="180" Height="100">
					<!-- Felt (green playing surface) -->
					<Rectangle Canvas.Left="10" Canvas.Top="0" Width="160" Height="100"
                               Fill="#1E824C" RadiusX="15" RadiusY="15" Stroke="SaddleBrown" StrokeThickness="3"/>
					<!-- Pockets (6 small black circles) -->
					<Ellipse Canvas.Left="5" Canvas.Top="-5" Width="10" Height="10" Fill="Black"/>
					<Ellipse Canvas.Left="85" Canvas.Top="-8" Width="10" Height="10" Fill="Black"/>
					<Ellipse Canvas.Left="165" Canvas.Top="-5" Width="10" Height="10" Fill="Black"/>
					<Ellipse Canvas.Left="5" Canvas.Top="95" Width="10" Height="10" Fill="Black"/>
					<Ellipse Canvas.Left="85" Canvas.Top="98" Width="10" Height="10" Fill="Black"/>
					<Ellipse Canvas.Left="165" Canvas.Top="95" Width="10" Height="10" Fill="Black"/>
				</Canvas>
			</Viewbox>

			<!-- 3. Timer and cost display -->
			<StackPanel Grid.Row="2"  Orientation="Vertical" Margin="0,10,0,5">
				<TextBlock Text="{Binding ElapsedTime, StringFormat='Time: {0:hh\\:mm\\:ss}', 
                            FallbackValue='Time: 00:00:00'}"
                           HorizontalAlignment="Center" FontSize="14" FontFamily="Consolas"/>
				<TextBlock Text="{Binding RatePerHour, StringFormat='Rate: {0:C}/hour',
                           FallbackValue='Rate: $10:00/hour'}"
                           HorizontalAlignment="Center" FontSize="11" Foreground="Gray"/>
				<TextBlock Text="{Binding CurrentCost, StringFormat='Cost: {0:C}',
                           FallbackValue='Cost: $0.00'}" HorizontalAlignment="Center"
                           FontWeight="Bold" Foreground="DarkRed"/>
			</StackPanel>

			<!-- 4. Control buttons -->
			<StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
				<Button Content="Start" Width="55" Margin="2"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding IsNotRunning}"/>
				<Button Content="Stop" Width="55"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsRunning}" RenderTransformOrigin="0.351,-1.596"/>
				<Button Content="Reset" Width="55" Margin="2"
                        Command="{Binding ResetCommand}"/>
			</StackPanel>
		</Grid>
	</Border>
</UserControl>
